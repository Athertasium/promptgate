{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@promptgate/shared": ["../shared/src/index.ts"]
    }
  },
  "include": ["src", "__tests__"],
  "exclude": ["dist", "node_modules"]
}
