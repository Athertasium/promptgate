// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Request {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at         DateTime         @default(now()) @db.Timestamptz
  tier               String
  served_by_provider String?
  served_by_model    String?
  input_tokens       Int?
  output_tokens      Int?
  cost_usd           Decimal?         @db.Decimal(10, 6)
  latency_ms         Int?
  cache_hit          Boolean          @default(false)
  cache_type         String?
  failover_occurred  Boolean          @default(false)
  caller_id          String?
  tags               String[]
  ttft_ms            Int?

  failover_events    FailoverEvent[]
  guardrail_events   GuardrailEvent[]
  semantic_cache_log SemanticCacheLog[]

  @@map("requests")
}

model FailoverEvent {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  request_id       String?  @db.Uuid
  created_at       DateTime @default(now()) @db.Timestamptz
  from_provider    String
  to_provider      String
  reason           String
  hop_number       Int?
  added_latency_ms Int?

  request          Request? @relation(fields: [request_id], references: [id])

  @@map("failover_events")
}

model GuardrailEvent {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  request_id String?  @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz
  check_type String
  action     String
  detail     Json?

  request    Request? @relation(fields: [request_id], references: [id])

  @@map("guardrail_events")
}

model SemanticCacheLog {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  request_id        String?  @db.Uuid
  created_at        DateTime @default(now()) @db.Timestamptz
  similarity_score  Float
  would_have_hit    Boolean
  matched_cache_key String?

  request           Request? @relation(fields: [request_id], references: [id])

  @@map("semantic_cache_log")
}

model ApiKey {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key_hash        String    @unique
  caller_id       String
  created_at      DateTime  @default(now()) @db.Timestamptz
  revoked_at      DateTime? @db.Timestamptz
  rate_limit_rpm  Int       @default(60)
  allowed_tiers   String[]  @default(["fast", "balanced", "smart", "thinking"])

  @@map("api_keys")
}

model ModelTierEntry {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tier                String
  provider            String
  model               String
  priority            Int
  enabled             Boolean  @default(true)
  cost_per_1m_input   Float
  cost_per_1m_output  Float
  routing_strategy    String   @default("priority")
  updated_at          DateTime @default(now()) @updatedAt @db.Timestamptz

  @@map("model_tier_entries")
}
